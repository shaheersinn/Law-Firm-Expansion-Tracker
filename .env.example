# Copy this file to .env for local development
# In GitHub Actions, these are set as Secrets (never committed)

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional tuning
INSTANT_ALERT_ON_LATERAL=true
DB_PATH=law_firm_tracker.db
REQUEST_TIMEOUT=20
MIN_DELAY_SECS=1.0
MAX_DELAY_SECS=3.0
